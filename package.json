{
	"name": "wheel-spin-game",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "concurrently -n web,api -c yellow,cyan \"vite dev\" \"npm run dev:server\"",
		"dev:server": "npm --prefix server run dev",
		"build": "npm install --prefix server && vite build",
		"start": "npm start --prefix server",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch"
	},
	"engines": {
		"node": ">=20"
	},
	"devDependencies": {
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/vite": "^4.3.0",
		"@types/node": "^25.8.0",
		"@vitest/ui": "^4.1.6",
		"concurrently": "^9.2.1",
		"jsdom": "^29.1.1",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"tailwindcss": "^4.3.0",
		"typescript": "^6.0.2",
		"vite": "^8.0.7",
		"vitest": "^4.1.6"
	},
	"dependencies": {
		"@sveltejs/adapter-node": "^5.5.4",
		"gsap": "^3.15.0",
		"mongodb": "^7.2.0"
	}
}
