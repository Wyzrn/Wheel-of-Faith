# API_URL — server-side only (NO VITE_ prefix — must NOT be exposed to the browser).
# Used exclusively in +page.server.ts load functions to call the Fastify backend directly.
# In production on Heroku, defaults to http://localhost:$PORT (same process, no env var needed).
# In dev, defaults to http://localhost:3001.
# API_URL=http://localhost:3001

# MongoDB Atlas connection string (required in production)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/wheel-of-fate

# Set to production on Heroku (Heroku sets this automatically)
# NODE_ENV=production

# Heroku sets PORT automatically — do not set manually on Heroku
# PORT=3001

# Optional: CORS allowed origin (defaults to localhost:5173 in dev)
# FRONTEND_URL=https://wheel-of-fate.herokuapp.com
