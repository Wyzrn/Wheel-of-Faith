PORT=3001
MONGODB_URI=mongodb://127.0.0.1:27017/wheel-of-fate
FRONTEND_URL=http://localhost:5173
NODE_ENV=development

# ─── AI character portraits (optional) ───────────────────────────────────────
# All 6 vars must be set together. If any are missing, portrait generation is
# silently disabled and the app falls back to the existing letter sigil.
# See .planning/AI_IMAGE_GENERATION_PLAN.md for the design rationale.

# fal.ai API key — https://fal.ai/dashboard/keys
FAL_API_KEY=

# Cloudflare R2 — https://dash.cloudflare.com/?to=/:account/r2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=wheel-of-fate-portraits
# Public URL bound to the bucket (custom domain or pub-*.r2.dev subdomain).
# No trailing slash.
R2_PUBLIC_URL=
